<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.trashcamp.frontend.controller.LoginController"
            styleClass="login-root">
    <children>
        <HBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

            <!-- ========== KIRI: Branding Panel ========== -->
            <VBox styleClass="login-left" prefWidth="420" alignment="CENTER" spacing="20">
                <padding><Insets top="40" right="36" bottom="40" left="36"/></padding>

                <!-- Eco icon ornament -->
                <Label text="🏔" styleClass="app-eco-icon"/>

                <VBox spacing="12" alignment="CENTER">
                    <Label text="TrashCamp" styleClass="app-title"/>
                    <Label styleClass="app-subtitle"
                           text="Kelola Sampah Pendakian&#10;Satu Sistem, Semua Tercatat"
                           alignment="CENTER" textAlignment="CENTER"/>
                </VBox>

                <Label text="🏕  Petugas Pos  •  Single-Role" styleClass="app-badge"/>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Stats teaser -->
                <HBox spacing="24" alignment="CENTER">
                    <VBox alignment="CENTER" spacing="4">
                        <Label text="1,240+" style="-fx-text-fill:white;-fx-font-size:20px;-fx-font-weight:bold;"/>
                        <Label text="Pendaki" style="-fx-text-fill:rgba(255,255,255,0.65);-fx-font-size:11px;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4">
                        <Label text="450 kg" style="-fx-text-fill:white;-fx-font-size:20px;-fx-font-weight:bold;"/>
                        <Label text="Sampah Tercatat" style="-fx-text-fill:rgba(255,255,255,0.65);-fx-font-size:11px;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="4">
                        <Label text="94%" style="-fx-text-fill:white;-fx-font-size:20px;-fx-font-weight:bold;"/>
                        <Label text="Eco Score" style="-fx-text-fill:rgba(255,255,255,0.65);-fx-font-size:11px;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- ========== KANAN: Login Form ========== -->
            <VBox HBox.hgrow="ALWAYS" alignment="CENTER"
                  style="-fx-background-color:#F0FAF5;">
                <padding><Insets top="60" right="80" bottom="60" left="80"/></padding>

                <VBox styleClass="login-card" spacing="20" maxWidth="420">
                    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

                    <!-- Header -->
                    <VBox spacing="6">
                        <Label text="Selamat Datang 👋" styleClass="login-title"/>
                        <Label text="Masuk ke sistem manajemen TrashCamp" styleClass="login-subtitle"/>
                    </VBox>

                    <!-- Error message -->
                    <Label fx:id="lblError" text="" styleClass="login-error" visible="false" managed="false" wrapText="true"/>

                    <!-- Username -->
                    <VBox spacing="6">
                        <Label text="Username" styleClass="form-label"/>
                        <TextField fx:id="tfUsername" styleClass="text-input"
                                   promptText="Masukkan username Anda"
                                   onAction="#onLoginClicked"/>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="6">
                        <Label text="Password" styleClass="form-label"/>
                        <PasswordField fx:id="pfPassword" styleClass="text-input"
                                       promptText="Masukkan password Anda"
                                       onAction="#onLoginClicked"/>
                    </VBox>

                    <!-- Login Button -->
                    <Button text="Masuk ke Dashboard →" styleClass="primary-button"
                            maxWidth="Infinity" onAction="#onLoginClicked"/>

                    <!-- Hint -->
                    <Label styleClass="login-hint"
                           text="Tahap ini: login berhasil jika username &amp; password tidak kosong."
                           wrapText="true" alignment="CENTER" textAlignment="CENTER"/>
                </VBox>
            </VBox>

        </HBox>
    </children>
</AnchorPane>
